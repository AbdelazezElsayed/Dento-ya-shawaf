# ==============================================
# Dento-HealthCare Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ==============================================

# ==============================================
# DATABASE (REQUIRED)
# ==============================================
# MongoDB connection string
# Local development: mongodb://localhost:27017/dento-health-care
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/dento?retryWrites=true&w=majority
# Get your connection string from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb://localhost:27017/dento-health-care

# ==============================================
# SESSIONS & SECURITY (REQUIRED)
# ==============================================
# Session secret for encrypting cookies
# CRITICAL: MUST be 64+ characters in production for security
# Generate a secure random secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# Example (DO NOT USE THIS IN PRODUCTION):
SESSION_SECRET=GENERATE_A_64_CHARACTER_SECRET_DO_NOT_USE_THIS_VALUE_IN_PRODUCTION_PLEASE

# ==============================================
# AI/ML SERVICES (REQUIRED for AI features)
# ==============================================
# Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
# Required for AI chat and diagnosis features
# SECURITY: Generate your own key - NEVER commit real keys to version control!
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================
# SERVER CONFIGURATION
# ==============================================
# Port for the application server
PORT=5000

# Environment mode: development | production | test
NODE_ENV=development

# Allowed CORS origins (comma-separated)
# Development: Leave empty or use http://localhost:5000,http://localhost:5173
# Production: Use your actual domain(s)
# Example: https://dento.com,https://www.dento.com,https://admin.dento.com
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173

# ==============================================
# LOGGING (Optional)
# ==============================================
# Log level: error | warn | info | debug
# Default: info
LOG_LEVEL=info

# Directory for log files (used in production)
# Default: logs
LOG_DIR=logs

# ==============================================
# RATE LIMITING (Optional - Override Defaults)
# ==============================================
# General API rate limit (requests per 15 minutes)
# Default: 100 requests per 15min window
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Authentication endpoints rate limit
# Default: 5 requests per 15min window
# AUTH_RATE_LIMIT_MAX=5
# AUTH_RATE_LIMIT_WINDOW_MS=900000

# AI endpoints rate limit
# Default: 10 requests per 15min window
# AI_RATE_LIMIT_MAX=10
# AI_RATE_LIMIT_WINDOW_MS=900000

# ==============================================
# EMAIL NOTIFICATIONS (Optional - Future Feature)
# ==============================================
# Uncomment and configure when implementing email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@dento-healthcare.com

# ==============================================
# PAYMENT GATEWAY (Optional - Future Feature)
# ==============================================
# Uncomment and configure when implementing payment processing
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ==============================================
# FILE STORAGE (Optional - Future Enhancement)
# ==============================================
# Currently using GridFS (MongoDB built-in)
# Uncomment for external storage providers (AWS S3, etc.)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=dento-xrays
